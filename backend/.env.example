SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=manufacture
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432
SPREADSHEET_PATH=C:/Users/zentu/Downloads/Shipment Stock Sheet (1).xlsx

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Phloe staff sync
PHLOE_API_URL=https://nbneplatform-production.up.railway.app
PHLOE_API_TOKEN=

# Bug report SMTP (IONOS)
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=587
SMTP_USER=toby@nbnesigns.com
SMTP_PASSWORD=

# ----- Amazon SP-API (shared by barcodes, restock, and FBA automation) -----
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN_EU=
AMAZON_REFRESH_TOKEN_NA=
AMAZON_REFRESH_TOKEN_AU=

# ----- FBA Shipment Automation (Phase 2) -----
# SANDBOX is only good for schema validation — use PRODUCTION for real placements.
SP_API_ENVIRONMENT=PRODUCTION
# Django-Q2 worker count (scale up if plan volume grows)
Q_CLUSTER_WORKERS=2
# Ship-from snapshot (copied onto each plan at creation time)
FBA_SHIP_FROM_NAME=NBNE Print & Sign Ltd
FBA_SHIP_FROM_COMPANY=NBNE Print & Sign Ltd
FBA_SHIP_FROM_LINE1=
FBA_SHIP_FROM_LINE2=
FBA_SHIP_FROM_CITY=Alnwick
FBA_SHIP_FROM_STATE=
FBA_SHIP_FROM_COUNTRY=GB
FBA_SHIP_FROM_POSTCODE=
FBA_SHIP_FROM_PHONE=
FBA_SHIP_FROM_EMAIL=
# Alerting for stuck/errored plans (runs via fba_alert_stuck_plans cron)
FBA_ALERT_RECIPIENT=toby@nbnesigns.com

# ----- Sales Velocity Module (Phase 2B) -----
# Shadow-mode cutover gate. While False, the aggregator writes to
# SalesVelocityHistory but does NOT touch StockLevel.sixty_day_sales.
# Flip to True only after eyeballing the Shadow/Live diff panel in the
# Sales Velocity tab for N days (Ben picks N — 14 is a reasonable default).
SALES_VELOCITY_WRITE_ENABLED=False

# Cross-service read-only access to Cairn's /etsy/sales endpoint.
# Manufacture holds NO Etsy credentials — Etsy OAuth lives inside Cairn
# (core/etsy_intel/) and is accessed via HTTP per the hard rule against
# cross-module direct DB access. See docs/sales_velocity_brief.md Phase 2B.3.
# CAIRN_API_KEY must match CLAW_API_KEY in Cairn's .env on the Cairn host.
CAIRN_API_URL=http://nbne1:8765
CAIRN_API_KEY=

# eBay Sell API credentials. Reused from the render app's existing eBay
# developer app — same client ID/secret, but manufacture runs its own
# one-time consent flow (/admin/oauth/ebay/connect) to get a separate
# refresh token stored in sales_velocity.OAuthCredential. This does not
# affect render's separate token grant.
# EBAY_RU_NAME is manufacture-specific and must be registered as a second
# redirect URI on the eBay dev app alongside render's existing RU name.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
EBAY_ENVIRONMENT=production
